{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "📊 Total Requests",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prom-ds" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "request_total", "legendFormat": "Requests" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue", "value": null },
            { "color": "green", "value": 10 }
          ]},
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "area",
        "justifyMode": "center", "textMode": "auto", "orientation": "auto"
      }
    },
    {
      "title": "🚨 Error Rate (%)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prom-ds" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "sum(rate(request_errors_total[5m])) / sum(rate(request_total[5m])) * 100 or vector(0)", "legendFormat": "Error %" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]},
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "none", "justifyMode": "center"
      }
    },
    {
      "title": "⏱️ Avg Latency (ms)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prom-ds" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "rate(request_latency_ms_sum[5m]) / rate(request_latency_ms_count[5m])", "legendFormat": "Avg Latency" }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 500 },
            { "color": "red", "value": 1000 }
          ]},
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "area", "justifyMode": "center"
      }
    },
    {
      "title": "🔢 PII Redacted (Total)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prom-ds" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "pii_scrub_total", "legendFormat": "PII Masked" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "orange", "value": null },
            { "color": "red", "value": 50 }
          ]},
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "none", "justifyMode": "center"
      }
    },
    {
      "title": "💰 Total Cost (USD)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prom-ds" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "targets": [{ "expr": "request_cost_usd_total", "legendFormat": "Cost" }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 5,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "red", "value": 2.5 }
          ]}
        }
      }
    },
    {
      "title": "📈 Traffic (Requests/sec)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prom-ds" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 4 },
      "targets": [{ "expr": "rate(request_total[1m])", "legendFormat": "Requests/sec" }],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "⚡ Latency Percentiles P50 / P95 / P99",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prom-ds" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(request_latency_ms_bucket[1m])))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(request_latency_ms_bucket[1m])))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(request_latency_ms_bucket[1m])))", "legendFormat": "P99" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "red", "value": 3000 }
          ]}
        }
      }
    },
    {
      "title": "🧪 Feature Distribution (from Logs)",
      "type": "piechart",
      "datasource": { "type": "loki", "uid": "loki-ds" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "targets": [{ "expr": "sum by (feature) (count_over_time({job=\"api_logs\", event=\"request_received\"} [15m]))", "legendFormat": "{{feature}}" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },
    {
      "title": "💸 Cost Rate (USD/min)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prom-ds" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "targets": [{ "expr": "rate(request_cost_usd_total[1m]) * 60", "legendFormat": "Cost/min" }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 5,
          "color": { "fixedColor": "yellow", "mode": "fixed" },
          "custom": { "fillOpacity": 15 }
        }
      }
    },
    {
      "title": "🔤 Tokens In / Out (rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prom-ds" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "targets": [
        { "expr": "rate(request_tokens_in_total[1m])", "legendFormat": "In" },
        { "expr": "rate(request_tokens_out_total[1m])", "legendFormat": "Out" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "👤 Top Active Sessions",
      "type": "barchart",
      "datasource": { "type": "loki", "uid": "loki-ds" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [{ "expr": "topk(5, sum by (session_id) (count_over_time({job=\"api_logs\", event=\"request_received\"} [15m])))", "legendFormat": "{{session_id}}" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    },
    {
      "title": "🤖 Model Activity Distribution",
      "type": "piechart",
      "datasource": { "type": "loki", "uid": "loki-ds" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [{ "expr": "sum by (model) (count_over_time({job=\"api_logs\", event=\"request_received\"} [15m]))", "legendFormat": "{{model}}" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },
    {
      "title": "🎯 Quality Score (current)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prom-ds" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 36 },
      "targets": [{ "expr": "request_quality_score_sum / request_quality_score_count", "legendFormat": "Quality" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "green", "value": 0.75 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "justifyMode": "center" }
    },
    {
      "title": "💬 Recent Messages & Answer Previews (PII-Scrubbed)",
      "type": "table",
      "datasource": { "type": "loki", "uid": "loki-ds" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 44 },
      "targets": [
        {
          "expr": "{job=\"api_logs\", event=\"request_received\"} | json | line_format \"{{.ts}} | {{.correlation_id}} | {{.feature}} | {{.message}}\"",
          "format": "table"
        }
      ]
    },
    {
      "title": "📜 Live API Logs (Tracing Feed)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki-ds" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 54 },
      "targets": [{ "expr": "{job=\"api_logs\"}", "legendFormat": "API Log" }],
      "options": { "showTime": true, "enableLogDetails": true, "sortOrder": "Descending" }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": [],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Lab 13 Observability Dashboard",
  "uid": "lab13-obs",
  "version": 9,
  "weekStart": ""
}
